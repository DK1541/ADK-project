# ============================================================
# Model provider — choose one: ollama | anthropic | huggingface | google
# ============================================================
MODEL_PROVIDER=ollama

# ============================================================
# Anthropic / Claude
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# Ollama (local — no API key needed)
# Install: https://ollama.com
# ============================================================
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2                        # default fallback for all specialists

# Per-specialist model assignments (each falls back to OLLAMA_MODEL if not set)
# Best model per task — pull with: ollama pull <model>
OLLAMA_MODEL_WEATHER=llama3.2:latest
OLLAMA_MODEL_TIME=llama3.1:latest
OLLAMA_MODEL_TRAVEL=qwen2.5:14b
OLLAMA_MODEL_MATH=qwen2.5:14b
OLLAMA_MODEL_LANGUAGE=aya-expanse:32b        # best multilingual/translation model
OLLAMA_MODEL_CODE=qwen2.5-coder:14b         # specialized code model
OLLAMA_MODEL_KNOWLEDGE=phi4                  # strong reasoning and research
OLLAMA_MODEL_MEDIA=minicpm-v                # vision + tool-calling — can see images AND call tools
                                             # pull with: ollama pull minicpm-v
OLLAMA_MODEL_COORDINATOR=qwen2.5:14b

# ── Pull these models before first run ───────────────────────
# ollama pull llama3.2
# ollama pull llama3.1
# ollama pull qwen2.5:14b
# ollama pull qwen2.5-coder:14b
# ollama pull phi4
# ollama pull llava:13b
# ollama pull aya-expanse:32b              (20GB — use aya:8b if RAM is limited)
# ollama pull qwen2.5:32b                  (optional — upgrade coordinator)

# ============================================================
# HuggingFace Inference API
# Get your token: https://huggingface.co/settings/tokens
# Best free models with tool-calling (Sambanova-routed):
#   huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct   (best, no gating)
#   huggingface/sambanova/meta-llama/Llama-3.3-70B-Instruct  (needs Meta license)
#   huggingface/together/deepseek-ai/DeepSeek-R1
# ============================================================
HF_TOKEN=hf_your_token_here
HF_MODEL=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct

# Per-specialist HuggingFace overrides (all fall back to HF_MODEL)
HF_MODEL_WEATHER=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_TIME=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_TRAVEL=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_MATH=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_LANGUAGE=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_CODE=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_KNOWLEDGE=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_MEDIA=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct
HF_MODEL_COORDINATOR=huggingface/sambanova/Qwen/Qwen2.5-72B-Instruct

# ============================================================
# Google Gemini
# Get your key: https://aistudio.google.com/app/apikey
# ============================================================
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your_google_api_key_here
